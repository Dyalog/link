{
     tests:[
     {
         id:'basic',
         test:'./Test/dtestrunner.aplf',
         dtestmodifiers:'-SuccessValue=apl!1',
         env:{
             CITA_APIDEV:0,
             DYALOGLINK: "${THISPATH}"
         }
     },
     {
         id:'all',
         test:'./Test/dtestrunner.aplf',
         dtestmodifiers:'-SuccessValue=apl!1',
         env:{
             CITA_APIDEV:0,
             DYALOGLINK:"${THISPATH}"
         }
     }
     ],
     defaults: {
        dyalogversions:  "19+",
        secondstimeout: 600,
        platforms: ["win","macx86","macarm","pi","linux"]
     }
 }
