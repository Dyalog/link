 dtestrunner nul;log;res;nl
 logв†ђ''  вЌќ any messages
 resв†ђ1 вЌќ ВЇ1: err, 0=fail, 1=ok
 nlв†ђвЋ•UCS 10

 :Trap 0
     :If 0=вЋ•SE.вЋ•NC'Link'
