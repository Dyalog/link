 ns‚Üê‚çéname
 ns.‚éïFX'foo' '2+2'
 ns.‚éïFX'bar' '3+3'
 1 ns.‚éïSTOP'foo'   ‚çù Check that Link.Add will NOT register existing stops
 z‚Üê‚éïSE.Link.Add name‚àò,¬®'.foo' '.bar'
 files‚Üê2‚äÉ¬®‚éïNPARTS‚äÉ‚éïNINFO‚çÝ1‚ä¢folder,'/*'
