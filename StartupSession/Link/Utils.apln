      r,‚Üź'{"Name":"Break",       "args":"[ns1]",             "Parse":"9999S -all[=]# ‚éēSE * -recursive=on off error",  "Desc":"Break link between namespace and corresponding directory"},'
      ‚ćĚr,‚Üź'{"Name":"CaseCode",    "args":"file1",             "Parse":"1L", "Desc":"Append filename with numeric encoding of capitalisation"},'
      r,‚Üź'{"Name":"Create",      "args":"[ns] dir",          "Parse":"1-2L -source=ns dir auto -watch=none ns dir both -casecode -forceextensions -forcefilenames -arrays[=] -sysvars -flatten -beforeread= -beforewrite= -getfilename= -codeextensions= -typeextensions= -fastload -ignoreconfig -text=aplan plain -recordflags","Desc":"Link a namespace with a directory (create one but not both if non-existent)"},'
      r,‚Üź'{"Name":"Configure",   "args":"target [settings]", "Parse":"1-9999 -create", "Desc":"Set directory or user configuration options"},'
      r,‚Üź'{"Name":"Export",      "args":"ns0 dir2",          "Parse":"1-2L -overwrite -arrays[=] -sysvars -casecode -ignoreconfig -text=aplan plain -recordflags", "Desc":"Export a namespace to a directory (create the directory if absent); does not create a link"},'
      r,‚Üź'{"Name":"Expunge",     "args":"[item]",            "Parse":"9999S",  "Desc":"Erase item and associated file"},'
      r,‚Üź'{"Name":"GetFileName", "args":"item",              "Parse":"1",  "Desc":"Return name of file associated with item"},'
      r,‚Üź'{"Name":"GetItemName", "args":"file",              "Parse":"1L", "Desc":"Return name of item associated with file"},'
      r,‚Üź'{"Name":"Import",      "args":"ns2 dir0",          "Parse":"1-2L -overwrite -flatten -fastload  -ignoreconfig", "Desc":"Import a namespace from a directory (create the namespace if absent); does not create a link"},'
      ‚ćĚr,‚Üź'{"Name":"Pause",       "args":"ns1",               "Parse":"1", "Desc":"Pause synchronisation between namespace and directory"},'
      r,‚Üź'{"Name":"Status",      "args":"[ns1]",             "Parse":"1S -extended", "Desc":"List active namespace-directory links"},'
      r,‚Üź'{"Name":"Stop",        "args":"item [lines]", "Parse":"1-9999 ","Desc":"Set, clear or report on breakpoints"},'
