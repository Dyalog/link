      r,‚Üź'{"Name":"Resync",      "args":"[ns1]",        "Parse":"1S  -proceed -arrays[=] -sysvars", "Desc":"Automatically synchronise namespace-directory differences"},'
      r‚Üź‚éēJSON']',‚ć®¬Į1‚Üďr
